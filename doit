#!/usr/bin/env python3
"""doit - an interactive LLM agent that turns natural language into shell commands.

Take a natural-language request, get an LLM to translate it into a single shell
command, classify how risky that command is, ask for confirmation when needed,
run it, and show the result.

There are two ways of getting the command out of the model, chosen by the
`tool_calling` flag in ~/doit.cfg:

  * prompt-and-parse (default): the model is asked, via the system prompt, to
    reply with a JSON object that we parse ourselves. Works with ANY model.
  * native tool-calling: the model is given a `run_shell_command` tool and
    answers with a structured tool call that the provider hands back cleanly.
    Only models trained for tool use (e.g. lfm2.5) do this well; weaker models
    should stay on prompt-and-parse.

On top of the basics, the prompt-and-parse path adds the "context" half of the
assignment:

  * persistent state under ~/.doit/
  * multi-turn history (JSONL), so a turn can refer to previous ones
  * per-terminal sessions, so two windows keep separate history streams
  * persistent memory about the user, surviving new shells / directories
  * user-awareness: reads the real shell history to see what the user did by hand
  * a project-profile extension (.doit.md), so the agent behaves per-folder

Every invocation of doit is its own process / its own turn; everything that has
to survive between turns lives on disk under ~/.doit/.
"""

import json
import os
import subprocess
import sys
import time
import uuid
from configparser import ConfigParser
from pathlib import Path

try:
    import litellm
except ImportError:
    sys.exit("doit: the 'litellm' package is required. Run: pip install litellm")


# ---------------------------------------------------------------------------
# Paths and constants
# ---------------------------------------------------------------------------

CONFIG_PATH = Path.home() / "doit.cfg"
STATE_DIR = Path.home() / ".doit"
HISTORY_PATH = STATE_DIR / "history.jsonl"
MEMORY_PATH = STATE_DIR / "memory.jsonl"
SESSIONS_DIR = STATE_DIR / "sessions"

# How a command is allowed to run.
SAFE = "safe"          # read-only, run without asking
CONFIRM = "confirm"    # modifies the filesystem / state, ask first

# How much context we feed back to the model.
MAX_SESSION_TURNS = 8        # recent turns from THIS terminal
MAX_OTHER_TURNS = 4          # recent turns from OTHER terminals (for cross-refs)
MAX_SHELL_LINES = 15         # recent manual shell commands
OUTPUT_CLIP = 1500           # chars of stdout/stderr we keep / show the model
MAX_CLARIFY_ROUNDS = 2       # how many times a turn may ask the user to clarify

# Project profile file name (the "agent.md" equivalent for a folder).
PROFILE_NAME = ".doit.md"


SYSTEM_PROMPT = """\
You are `doit`, an assistant that converts a user's natural-language request \
into a single shell command for bash on Linux, or answers them directly.

Respond with ONLY a JSON object (no markdown fences) with these fields:
  "kind": one of "command", "answer", "clarify", "refuse".
      - "command": the request maps to a shell command to run.
      - "answer":  the request is not a command to execute but should still get
                   a helpful reply -- a question ("how do I ...?"), small talk
                   ("tell me a joke"), a question about yourself, or a question
                   about previous output ("why did that fail?").
      - "clarify": the request is genuinely ambiguous in a way that would change
                   the command itself, and you cannot resolve it from context.
                   Ask ONE short question instead of guessing. Be useful, not
                   annoying: only clarify when it truly matters; if a sensible
                   default exists, just use it and run the command.
      - "refuse":  the request cannot be done as a shell command and is not a
                   question you can answer.
  "command": the shell command string (only when kind == "command", else "").
  "risk": one of "safe", "confirm" (only when kind == "command").
      - "safe":    read-only, no side effects (ls, cat, grep, find, df, ...).
      - "confirm": changes or destroys files or state -- creating, moving, or
                   deleting files, installing packages, writing to disks, etc.
                   (mkdir, mv, rm, dd, mkfs, pip install, git commit, ...).
  "answer": the text reply to show the user (only when kind == "answer" or
            "refuse"). Use a professional, neutral tone.
  "question": the single clarifying question to ask (only when kind ==
              "clarify"). Keep it short.
  "options": an optional list of short answer choices for the question (only
             when kind == "clarify"), shown to the user as a numbered menu.
             Empty list if the question is open-ended.
  "explanation": one short sentence explaining the command (only when
                 kind == "command").
  "cd": a directory to navigate to, when the user asks to "move to" / "go to"
        a folder. Use this field for navigation instead of a `cd` command (a
        child process cannot change the parent shell). Use `~` for the home
        directory; NEVER guess an absolute /home/<name> path. Empty when not
        navigating.
  "memories_to_store": a list of short durable facts about the USER worth
        remembering across sessions (preferences, project locations, standing
        instructions like "always sort newest first"). Empty list if none.
        Only store things that are clearly meant to persist. IMPORTANT: when the
        user labels something ("this is my X folder", "call this my Y",
        "remember that ...", "from now on ..."), store that as a memory even if
        the same turn also performs an action like navigating.
  "memories_to_forget": a list of memory ids (integers shown in MEMORY) to drop
        when the user changes their mind. Empty list if none.

You are given context: stored MEMORY about the user, the current PROJECT PROFILE,
recent SHELL ACTIVITY the user ran by hand, and the multi-turn HISTORY of this
session (and brief notes from other terminals). Use them to resolve references
like "now sort them by date", "do it again here", or "go to my class project".

Prefer a single command. Do not invent file names the user did not mention."""


# Used only on the native tool-calling path. The structured contract lives in
# SHELL_TOOL below, so this prompt is deliberately short -- the model decides
# between "call the tool" and "answer in text" instead of emitting JSON.
TOOL_SYSTEM_PROMPT = """\
You are `doit`, an assistant that helps the user by running shell commands on \
bash/Linux.

When the user's request maps to a shell command, you MUST call the \
`run_shell_command` tool with the command, its risk level, and a one-sentence \
explanation. Do NOT describe the command in prose or in a code block -- always \
express it as a tool call. This includes state-changing actions (creating, \
moving, deleting, installing): call the tool; the harness handles asking the \
user for confirmation. Prefer a single command. Do not invent file names the \
user did not mention.

If the request is not something to run -- a question ("how do I ...?"), small \
talk, or something you cannot do as a shell command -- do NOT call the tool. \
Just reply with a short, helpful text answer in a professional, neutral tone."""


SHELL_TOOL = {
    "type": "function",
    "function": {
        "name": "run_shell_command",
        "description": (
            "Run a single bash shell command on the user's Linux machine to "
            "fulfil their request."
        ),
        "parameters": {
            "type": "object",
            "properties": {
                "command": {
                    "type": "string",
                    "description": "The bash command to run.",
                },
                "risk": {
                    "type": "string",
                    "enum": [SAFE, CONFIRM],
                    "description": (
                        "safe = read-only, no side effects (ls, cat, grep). "
                        "confirm = changes or destroys files or state "
                        "(rm, mv, mkdir, pip install)."
                    ),
                },
                "explanation": {
                    "type": "string",
                    "description": "One short sentence explaining the command.",
                },
            },
            "required": ["command", "risk", "explanation"],
        },
    },
}


# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

def load_config():
    """Read ~/doit.cfg. Returns a dict of model settings."""
    cfg = ConfigParser()
    if CONFIG_PATH.exists():
        cfg.read(CONFIG_PATH)
    model_section = cfg["model"] if cfg.has_section("model") else {}

    settings = {
        "model": model_section.get("model", "gpt-4o-mini"),
        "api_key": model_section.get("api_key", ""),
        "api_base": model_section.get("api_base", ""),
        "temperature": model_section.getfloat("temperature", 0.0)
        if model_section else 0.0,
        "tool_calling": model_section.getboolean("tool_calling", False)
        if model_section else False,
    }
    return settings


# ---------------------------------------------------------------------------
# State directory / session identity
# ---------------------------------------------------------------------------

def ensure_state():
    """Create ~/.doit/ (and sessions/) on first use."""
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)


def session_id():
    """Identify the terminal this invocation came from.

    Preference order:
      1. $DOIT_SESSION_ID  -- set by the .bashrc snippet, one per terminal.
      2. ppid-<n>          -- the parent shell's pid is stable across doit
                              calls from the same window, so it cleanly
                              separates two terminals even without the snippet.
    """
    env_id = os.environ.get("DOIT_SESSION_ID", "").strip()
    if env_id:
        return env_id
    return f"ppid-{os.getppid()}"


# ---------------------------------------------------------------------------
# History (multi-turn, per-session streams)
# ---------------------------------------------------------------------------

def save_interaction(record):
    """Append one turn to the history JSONL log."""
    ensure_state()
    record = dict(record)
    record.setdefault("ts", time.time())
    with HISTORY_PATH.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(record, ensure_ascii=False) + "\n")


def load_history():
    """Read every recorded turn (oldest first). Tolerant of bad lines."""
    if not HISTORY_PATH.exists():
        return []
    out = []
    for line in HISTORY_PATH.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            out.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return out


def _clip(text, limit=OUTPUT_CLIP):
    text = text or ""
    if len(text) > limit:
        return text[:limit] + "\n...[truncated]"
    return text


def turn_to_messages(turn):
    """Render one stored turn as chat messages (for THIS session's history)."""
    msgs = [{"role": "user", "content": turn.get("instruction", "")}]
    kind = turn.get("kind")
    if kind == "command":
        cmd = turn.get("command", "")
        expl = turn.get("explanation", "")
        msgs.append({"role": "assistant",
                     "content": f"(ran command) {cmd}\n# {expl}".strip()})
        out = _clip(turn.get("stdout", ""))
        err = _clip(turn.get("stderr", ""))
        rc = turn.get("returncode", 0)
        tool = f"exit={rc}"
        if out:
            tool += f"\nstdout:\n{out}"
        if err:
            tool += f"\nstderr:\n{err}"
        # Output is fed back as a user-role note so providers that reject bare
        # tool messages (no tool_call) still accept the history.
        msgs.append({"role": "user", "content": f"[output]\n{tool}"})
    else:
        msgs.append({"role": "assistant", "content": turn.get("answer", "")})
    return msgs


def other_sessions_note(history, current_sid):
    """A compact, labelled summary of recent turns from OTHER terminals.

    This is what lets a user say "do the same thing we did in the other window"
    while normal references stay scoped to the current terminal.
    """
    others = [t for t in history if t.get("session") != current_sid]
    if not others:
        return ""
    lines = []
    for t in others[-MAX_OTHER_TURNS:]:
        sid = t.get("session", "?")
        instr = t.get("instruction", "")
        cmd = t.get("command", "")
        piece = f'- [{sid} @ {t.get("cwd", "?")}] "{instr}"'
        if cmd:
            piece += f"  ->  {cmd}"
        lines.append(piece)
    return "Recent activity in OTHER terminals (only use if explicitly asked):\n" + "\n".join(lines)


# ---------------------------------------------------------------------------
# Memory (persists across shells, dirs, sessions)
# ---------------------------------------------------------------------------

def load_memories():
    """Return list of {id, text, ts} memory records."""
    if not MEMORY_PATH.exists():
        return []
    out = []
    for line in MEMORY_PATH.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            out.append(json.loads(line))
        except json.JSONDecodeError:
            continue
    return out


def _rewrite_memories(records):
    ensure_state()
    with MEMORY_PATH.open("w", encoding="utf-8") as fh:
        for r in records:
            fh.write(json.dumps(r, ensure_ascii=False) + "\n")


def store_memories(texts):
    """Append new memory facts, skipping exact duplicates. Returns added ones."""
    if not texts:
        return []
    records = load_memories()
    existing = {r.get("text", "").strip().lower() for r in records}
    next_id = max([r.get("id", 0) for r in records], default=0) + 1
    added = []
    for text in texts:
        text = (text or "").strip()
        if not text or text.lower() in existing:
            continue
        rec = {"id": next_id, "text": text, "ts": time.time()}
        records.append(rec)
        added.append(rec)
        existing.add(text.lower())
        next_id += 1
    if added:
        _rewrite_memories(records)
    return added


def forget_memories(ids):
    """Drop memories by id. Returns the ids actually removed."""
    if not ids:
        return []
    want = {int(i) for i in ids if str(i).isdigit() or isinstance(i, int)}
    records = load_memories()
    kept = [r for r in records if r.get("id") not in want]
    removed = [r.get("id") for r in records if r.get("id") in want]
    if removed:
        _rewrite_memories(kept)
    return removed


def memory_block():
    records = load_memories()
    if not records:
        return ""
    lines = [f"  [{r['id']}] {r['text']}" for r in records]
    return "MEMORY (durable facts about the user):\n" + "\n".join(lines)


# ---------------------------------------------------------------------------
# User awareness (real shell history)
# ---------------------------------------------------------------------------

def read_shell_history(limit=MAX_SHELL_LINES):
    """Recent commands the user typed by hand, newest last.

    We read the shell's own history file. Lines that are doit invocations are
    tagged so the model can tell its own actions apart from the user's.
    """
    candidates = [
        os.environ.get("HISTFILE", ""),
        str(Path.home() / ".bash_history"),
        str(Path.home() / ".zsh_history"),
    ]
    path = next((p for p in candidates if p and Path(p).exists()), "")
    if not path:
        return []
    try:
        raw = Path(path).read_text(encoding="utf-8", errors="ignore").splitlines()
    except OSError:
        return []
    cleaned = []
    for line in raw:
        # zsh history lines look like ": 1700000000:0;the command"
        if line.startswith(":") and ";" in line:
            line = line.split(";", 1)[1]
        line = line.strip()
        if line:
            cleaned.append(line)
    return cleaned[-limit:]


def shell_activity_block():
    lines = read_shell_history()
    if not lines:
        return ""
    rendered = []
    for cmd in lines:
        who = "doit" if cmd.startswith(("doit ", "./doit ")) or cmd == "doit" else "user"
        rendered.append(f"  ({who}) {cmd}")
    return ("RECENT SHELL ACTIVITY (commands seen in the user's shell history, "
            "newest last):\n" + "\n".join(rendered))


# ---------------------------------------------------------------------------
# Project profiles (extension: behave differently per folder)
# ---------------------------------------------------------------------------

def find_project_profile(start=None):
    """Walk up from cwd to home looking for a .doit.md profile file."""
    start = Path(start or os.getcwd()).resolve()
    home = Path.home().resolve()
    for d in [start, *start.parents]:
        candidate = d / PROFILE_NAME
        if candidate.exists():
            try:
                return candidate, candidate.read_text(encoding="utf-8").strip()
            except OSError:
                return candidate, ""
        if d == home:
            break
    return None, ""


def project_profile_block():
    path, text = find_project_profile()
    if not text:
        return ""
    return (f"PROJECT PROFILE (from {path}; folder-specific instructions, "
            f"follow them here):\n{text}")


# ---------------------------------------------------------------------------
# Context assembly
# ---------------------------------------------------------------------------

def build_context(settings, instruction, sid):
    """Assemble the full message list sent to the model for this turn.

    Layered as: base system prompt + (memory, project profile, shell activity,
    cross-session notes) context blocks, then this session's multi-turn history
    as real chat messages, then the current instruction.
    """
    history = load_history()
    session_turns = [t for t in history if t.get("session") == sid]

    context_blocks = [b for b in (
        memory_block(),
        project_profile_block(),
        shell_activity_block(),
        other_sessions_note(history, sid),
        f"Current directory: {os.getcwd()}",
    ) if b]

    system = SYSTEM_PROMPT
    if context_blocks:
        system += "\n\n" + "\n\n".join(context_blocks)

    messages = [{"role": "system", "content": system}]
    for turn in session_turns[-MAX_SESSION_TURNS:]:
        messages.extend(turn_to_messages(turn))
    messages.append({"role": "user", "content": instruction})
    return messages


def call_llm(settings, messages, use_tools):
    """Low-level LiteLLM call. When use_tools is set, the model is offered the
    run_shell_command tool and may answer with a structured tool call."""
    kwargs = {
        "model": settings["model"],
        "messages": messages,
        "temperature": settings["temperature"],
    }
    if use_tools:
        kwargs["tools"] = [SHELL_TOOL]
        kwargs["tool_choice"] = "auto"
    if settings["api_key"]:
        kwargs["api_key"] = settings["api_key"]
    if settings["api_base"]:
        kwargs["api_base"] = settings["api_base"]
    return litellm.completion(**kwargs)


def ask_model(settings, messages):
    """Prompt-and-parse path: send the assembled context messages and parse the
    JSON reply."""
    response = call_llm(settings, messages, use_tools=False)
    content = response.choices[0].message.content.strip()

    # Be forgiving: strip accidental ```json fences before parsing.
    if content.startswith("```"):
        content = content.strip("`")
        content = content[content.find("{"):]
    try:
        return json.loads(content)
    except json.JSONDecodeError:
        return {"kind": "refuse", "command": "", "risk": CONFIRM,
                "answer": f"Could not parse model reply: {content[:200]}"}


# ---------------------------------------------------------------------------
# Execution
# ---------------------------------------------------------------------------

def run_command(command):
    """Execute a shell command and capture stdout/stderr/return code.

    Uses /bin/bash by default; $DOIT_BASH overrides it (handy on Windows/Git
    Bash where bash lives elsewhere).
    """
    print(f"$ {command}")
    result = subprocess.run(
        command, shell=True, executable=os.environ.get("DOIT_BASH", "/bin/bash"),
        capture_output=True, text=True,
    )
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    if result.returncode != 0:
        print(f"[exit code {result.returncode}]", file=sys.stderr)
    return result


def request_cd(sid, path):
    """Ask the shell wrapper to actually change the parent shell's directory.

    A child process cannot cd the parent, so we drop the target in a per-session
    file. The doit() shell function (see install snippet) sources and removes it.
    """
    ensure_state()
    target = os.path.expanduser(path)
    (SESSIONS_DIR / f"{sid}.cd").write_text(target, encoding="utf-8")
    print(f"cd {path}")


def confirm(prompt):
    try:
        return input(f"{prompt} [y/N] ").strip().lower() in ("y", "yes")
    except (EOFError, KeyboardInterrupt):
        print()
        return False


# ---------------------------------------------------------------------------
# Orchestration
# ---------------------------------------------------------------------------

def maybe_run(command, risk, explanation):
    """Shared command-gating used by the tool-calling path: announce, confirm if
    risky, run. Returns the completed process, or None if the user aborted."""
    print(f"# {explanation}")
    if risk == CONFIRM:
        print(f"Proposed command:\n  {command}")
        if not confirm("Run it?"):
            print("Aborted.")
            return None
    return run_command(command)


def render_clarify(reply):
    """One-line rendering of a clarify reply, echoed back into chat history."""
    question = (reply.get("question") or "Could you clarify what you mean?").strip()
    options = reply.get("options") or []
    if options:
        opts = "; ".join(f"{i}. {o}" for i, o in enumerate(options, 1))
        return f"{question} ({opts})"
    return question


def ask_clarification(reply):
    """Show the clarifying question (with an optional numbered menu) and return
    the user's answer. Returns None if the user gives no answer, so the caller
    can abort cleanly instead of guessing."""
    question = (reply.get("question") or "Could you clarify what you mean?").strip()
    options = reply.get("options") or []
    print(question)
    for i, opt in enumerate(options, 1):
        print(f"  {i}. {opt}")
    try:
        answer = input("> ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return None
    if not answer:
        return None
    # Let the user reply with the option number instead of retyping the text.
    if answer.isdigit() and 1 <= int(answer) <= len(options):
        answer = options[int(answer) - 1]
    return answer


def handle(settings, instruction, sid):
    """Prompt-and-parse path (default; works with any model). Uses full context:
    multi-turn history, memory, shell awareness, project profiles."""
    messages = build_context(settings, instruction, sid)
    reply = ask_model(settings, messages)

    # Clarification loop: when the request is genuinely ambiguous the model asks
    # one short question and we wait for an answer before continuing. Bounded so
    # an indecisive model can't loop forever.
    clarifications = []
    rounds = 0
    while reply.get("kind") == "clarify" and rounds < MAX_CLARIFY_ROUNDS:
        rounds += 1
        question = render_clarify(reply)
        answer = ask_clarification(reply)
        if answer is None:
            print("Aborted.")
            return
        clarifications.append(answer)
        messages.append({"role": "assistant", "content": question})
        messages.append({"role": "user", "content": answer})
        reply = ask_model(settings, messages)

    if reply.get("kind") == "clarify":
        # Still unsure after the allotted rounds: show the question, don't guess.
        print(render_clarify(reply))
        return

    kind = reply.get("kind", "refuse")

    # Side effects that apply regardless of kind: navigation + memory.
    cd_target = (reply.get("cd") or "").strip()
    if cd_target:
        request_cd(sid, cd_target)
    added = store_memories(reply.get("memories_to_store", []))
    removed = forget_memories(reply.get("memories_to_forget", []))
    for rec in added:
        print(f"(remembered: {rec['text']})")
    if removed:
        print(f"(forgot memory {', '.join(str(i) for i in removed)})")

    effective_instruction = instruction
    if clarifications:
        effective_instruction += " (clarified: " + "; ".join(clarifications) + ")"

    record = {
        "session": sid, "cwd": os.getcwd(), "instruction": effective_instruction,
        "kind": kind,
    }

    if kind in ("answer", "refuse"):
        answer = reply.get("answer", "") or (
            "doit: that can't be done as a shell command." if kind == "refuse" else "")
        if answer:
            print(answer)
        record["answer"] = answer
        save_interaction(record)
        return

    command = reply.get("command", "").strip()
    risk = reply.get("risk", CONFIRM)
    explanation = reply.get("explanation", "")
    record.update({"command": command, "risk": risk, "explanation": explanation})

    if not command:
        # Pure navigation / memory turn with no command is fine.
        if cd_target or added or removed:
            save_interaction(record)
            return
        print(f"doit: no command produced. {explanation}")
        save_interaction(record)
        return

    if explanation:
        print(f"# {explanation}")

    if risk == CONFIRM:
        print(f"Proposed command:\n  {command}")
        if not confirm("Run it?"):
            print("Aborted.")
            record["aborted"] = True
            save_interaction(record)
            return

    result = run_command(command)
    record.update({
        "stdout": _clip(result.stdout),
        "stderr": _clip(result.stderr),
        "returncode": result.returncode,
    })
    save_interaction(record)


def handle_tool_calling(settings, instruction):
    """Native tool-calling path: the model emits a structured tool call instead
    of JSON-in-text, and we feed the command's output back so it can summarise.
    Used when tool_calling = true in doit.cfg (model must support tools)."""
    messages = [
        {"role": "system", "content": TOOL_SYSTEM_PROMPT},
        {"role": "user", "content": instruction},
    ]
    message = call_llm(settings, messages, use_tools=True).choices[0].message
    tool_calls = message.tool_calls or []

    if not tool_calls:
        # The model chose to answer in plain text rather than run a command.
        print((message.content or "").strip() or "doit: nothing to do.")
        return

    # One command per request: act on the first tool call.
    call = tool_calls[0]
    try:
        args = json.loads(call.function.arguments)
    except (json.JSONDecodeError, TypeError):
        print(f"doit: could not parse tool arguments: {call.function.arguments!r}")
        return

    command = (args.get("command") or "").strip()
    risk = args.get("risk", CONFIRM)
    explanation = args.get("explanation", "")
    if not command:
        print(f"doit: tool call produced no command. {explanation}")
        return

    result = maybe_run(command, risk, explanation)
    if result is None:
        return

    # Feed the result back so the model can briefly summarise it. Seeing the
    # output is the real payoff of tool-calling over prompt-and-parse.
    messages.append({
        "role": "assistant",
        "content": message.content or "",
        "tool_calls": [{
            "id": call.id,
            "type": "function",
            "function": {
                "name": call.function.name,
                "arguments": call.function.arguments,
            },
        }],
    })
    output = (result.stdout or "") + (result.stderr or "")
    messages.append({
        "role": "tool",
        "tool_call_id": call.id,
        "content": output.strip() or f"[exit code {result.returncode}]",
    })
    try:
        summary = call_llm(settings, messages, use_tools=False).choices[0].message.content
        if summary and summary.strip():
            print(summary.strip())
    except Exception as exc:  # the summary is a nicety; never fail the run for it
        print(f"doit: (could not summarise result: {exc})", file=sys.stderr)


def main(argv):
    instruction = " ".join(argv).strip()
    if not instruction:
        sys.exit("usage: doit <natural language request>")
    settings = load_config()
    if settings["tool_calling"]:
        handle_tool_calling(settings, instruction)
    else:
        handle(settings, instruction, session_id())


if __name__ == "__main__":
    main(sys.argv[1:])
